WORKSPACE_LIMIT_PER_USER=3
MAX_SKILLS_PER_BOT=5

# Database URL for PostgreSQL (used by Prisma)
# Default matches docker-compose: postgres:postgres@localhost:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# Better Auth (sign-in with GitHub/Google)
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET="your-32-char-secret-here"

# Encrypt API keys at rest (32 chars, or use BETTER_AUTH_SECRET as fallback)
# Generate: openssl rand -base64 32
# ENCRYPTION_KEY="your-32-char-encryption-key"
BETTER_AUTH_URL="http://localhost:3000"

# GitHub OAuth - create app at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
# GITHUB_CLIENT_ID="Ov23li359UeSNGyBKrOF"
# GITHUB_CLIENT_SECRET="7ccf8dbd9942161eea8d4a7e5ea884c114c72ba4"

GITHUB_CLIENT_ID="Ov23liXrcnnVpuEcs5f0"
GITHUB_CLIENT_SECRET="c50b1ffe25835f722774d2212103cff65ac16246"

